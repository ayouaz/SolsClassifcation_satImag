# Copier ce fichier en .env et remplacer les valeurs

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID="votre_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="votre_secret"
OAUTH_CALLBACK_URL="http://localhost:8000/auth/google/callback"

# --- Google Earth Engine ---
GEE_SERVICE_ACCOUNT="email@service-account.iam.gserviceaccount.com"
GEE_PRIVATE_KEY_PATH="path/to/key.json"

# --- JWT Session ---
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET="changez-cette-valeur-en-production"

# --- Frontend ---
FRONTEND_URL="http://localhost:5500"
